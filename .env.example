# Session Security
# Generate a strong secret with: openssl rand -base64 32
SESSION_SECRET=your-32-character-secret-here

# Redis Configuration (Vercel KV or Upstash)
KV_URL=rediss://default:your-password@your-host:your-port
KV_REST_API_URL=https://your-host.upstash.io
KV_REST_API_TOKEN=your-rest-token-here

# Optional: Production Environment Flag
# NODE_ENV=production
